{
  "$comment": "STATUS: TESTED_ONLY — Trust Packet v1.1 schema is validated by tests but not imported by server.js; live Trust Packet v0 bridge is in server.js.",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bleu.live/schemas/trust-packet-v1.1.json",
  "title": "Trust Packet v1.1",
  "description": "Shadow-mode proof envelope for future BLEU record() output. Counterfactual is mandatory by schema-level constraint.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "signal_id",
    "decision_id",
    "response",
    "counterfactual",
    "outcome_plan",
    "audit"
  ],
  "properties": {
    "packet_id": { "type": "string", "format": "uuid" },
    "signal_id": { "type": "string", "format": "uuid" },
    "decision_id": { "type": "string", "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "surface": { "type": "string", "minLength": 1 },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hash", "model", "word_count", "evaluator_passed"],
      "properties": {
        "hash": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "word_count": { "type": "integer", "minimum": 0 },
        "evaluator_passed": { "type": "boolean" },
        "voice_scores": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "user": { "type": "number", "minimum": 0, "maximum": 1 },
            "clinical": { "type": "number", "minimum": 0, "maximum": 1 },
            "infrastructure": { "type": "number", "minimum": 0, "maximum": 1 },
            "restraint": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "counterfactual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "prevented_wrong_answer", "bleu_difference", "confidence"],
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "crisis_missed",
            "unsafe_supplement",
            "overclaim",
            "premature_commerce",
            "wrong_dose",
            "missed_referral",
            "privacy_leak",
            "voice_drift",
            "none"
          ]
        },
        "prevented_wrong_answer": { "type": "string", "minLength": 1 },
        "bleu_difference": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "outcome_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["day_3", "day_7", "day_30"],
      "properties": {
        "day_3": { "$ref": "#/$defs/outcome_checkpoint" },
        "day_7": { "$ref": "#/$defs/outcome_checkpoint" },
        "day_30": { "$ref": "#/$defs/outcome_checkpoint" }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code_version", "doctrine_refs", "refusals_checked", "pressures_countered", "td_010"],
      "properties": {
        "code_version": { "type": "string", "minLength": 1 },
        "doctrine_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "refusals_checked": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 20 }
        },
        "pressures_countered": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "td_010": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pii_hashed", "plaintext_email_stored", "plaintext_phone_stored"],
          "properties": {
            "pii_hashed": { "type": "boolean" },
            "plaintext_email_stored": { "const": false },
            "plaintext_phone_stored": { "const": false }
          }
        }
      }
    }
  },
  "$defs": {
    "outcome_checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "rationale"],
      "properties": {
        "status": { "type": "string", "enum": ["scheduled", "deferred", "not_applicable", "completed"] },
        "rationale": { "type": "string", "minLength": 1 },
        "metric": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 }
      }
    }
  }
}
