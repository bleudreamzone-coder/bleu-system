{
  "$comment": "STATUS: DORMANT — counterfactual review contract only; not imported by server.js.",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bleu.live/schemas/counterfactual-review-v1.1.json",
  "title": "CounterfactualReview v1.1",
  "description": "Shadow-mode human review record for Trust Packet counterfactual claims. Clinical counterfactual classes require Dr. Felicia authority tier review.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "trust_packet_id",
    "reviewer_id",
    "reviewer_tier",
    "schema_version",
    "reviewed_at",
    "verdict",
    "verdict_reason",
    "suggested_revision",
    "confidence",
    "counterfactual_class_reviewed",
    "clinical_review_required",
    "td_010_compliance"
  ],
  "properties": {
    "review_id": { "type": "string", "format": "uuid" },
    "trust_packet_id": { "type": "string", "format": "uuid" },
    "reviewer_id": { "type": "string", "minLength": 1 },
    "reviewer_tier": { "$ref": "#/$defs/reviewer_tier" },
    "schema_version": { "const": "1.1" },
    "reviewed_at": { "type": "string", "format": "date-time" },
    "verdict": { "$ref": "#/$defs/verdict" },
    "verdict_reason": { "type": "string", "minLength": 1 },
    "suggested_revision": { "type": ["string", "null"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "counterfactual_class_reviewed": { "$ref": "#/$defs/counterfactual_class" },
    "clinical_review_required": { "type": "boolean" },
    "td_010_compliance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pii_hashed", "plaintext_email_stored", "plaintext_phone_stored"],
      "properties": {
        "pii_hashed": { "type": "boolean" },
        "plaintext_email_stored": { "const": false },
        "plaintext_phone_stored": { "const": false }
      }
    }
  },
  "allOf": [
    {
      "if": { "type": "object", "properties": { "verdict": { "const": "requires_revision" } }, "required": ["verdict"] },
      "then": { "type": "object", "properties": { "suggested_revision": { "type": "string", "minLength": 1 } } },
      "else": { "type": "object", "properties": { "suggested_revision": { "const": null } } }
    },
    {
      "if": { "type": "object", "properties": { "clinical_review_required": { "const": true } }, "required": ["clinical_review_required"] },
      "then": { "type": "object", "properties": { "reviewer_tier": { "enum": ["tier_2_felicia", "tier_3_felicia_autonomous"] } } }
    },
    {
      "if": { "type": "object", "properties": { "counterfactual_class_reviewed": { "enum": ["crisis_missed", "unsafe_supplement", "missed_referral", "wrong_dose"] } }, "required": ["counterfactual_class_reviewed"] },
      "then": { "type": "object", "properties": { "clinical_review_required": { "const": true } } },
      "else": { "type": "object", "properties": { "clinical_review_required": { "const": false } } }
    }
  ],
  "$defs": {
    "reviewer_tier": {
      "type": "string",
      "enum": ["tier_1_captain", "tier_2_felicia", "tier_3_felicia_autonomous"]
    },
    "verdict": {
      "type": "string",
      "enum": ["confirmed", "disputed", "requires_revision", "insufficient_evidence"]
    },
    "counterfactual_class": {
      "type": "string",
      "enum": [
        "crisis_missed",
        "unsafe_supplement",
        "overclaim",
        "premature_commerce",
        "wrong_dose",
        "missed_referral",
        "privacy_leak",
        "voice_drift",
        "none"
      ]
    }
  }
}
